generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

@@schema(" corpus\)
model SecurityUser {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String              @map("tenant_id") @db.Uuid
  email               String              @unique(map: "idx_security_users_email_unique") @db.VarChar(255)
  passwordHash        String              @map("password_hash")
  name                String?             @map("name") @db.VarChar(255)
  isActive            Boolean?            @default(true) @map("is_active")
  createdAt           DateTime?           @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime?           @default(now()) @map("updated_at") @db.Timestamp(6)
  mustChangePassword  Boolean             @default(true) @map("must_change_password")
  lastLoginAt         DateTime?           @map("last_login_at") @db.Timestamptz(6)
  passwordUpdatedAt   DateTime?           @map("password_updated_at") @db.Timestamptz(6)
  activationStatus    String              @default("pending") @map("activation_status")
  lastName            String?             @map("last_name")
  whatsapp            String?             @map("whatsapp")
  roleId              String?             @map("role_id") @db.Uuid
  role                SecurityRbac?       @relation("UserPrimaryRole", fields: [roleId], references: [id])
  security_user_scope SecurityUserScope[]
  security_user_token SecurityUserToken[]
  user_x_rbac         UserXRbac[]

  @@map("security_users")
}

@@schema(" corpus\)
model SecurityUserScope {
  id                       String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                   String                  @map("user_id") @db.Uuid
  jurisdictionId           String?                 @map("jurisdiction_id") @db.Uuid
  frameworkVersionId       String?                 @map("framework_version_id") @db.Uuid
  domainId                 String?                 @map("domain_id") @db.Uuid
  isAllowed                Boolean                 @default(true) @map("is_allowed")
  createdAt                DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy                String?                 @map("created_by") @db.Uuid
  corpus_domain            CorpusDomain?           @relation(fields: [domainId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  corpus_framework_version CorpusFrameworkVersion? @relation(fields: [frameworkVersionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  corpus_jurisdiction      CorpusJurisdiction?     @relation(fields: [jurisdictionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  security_users           SecurityUser            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, jurisdictionId, frameworkVersionId, domainId], map: "idx_security_user_scope_unique")
  @@map("security_user_scope")
}

@@schema(" corpus\)
model SecurityUserToken {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  tokenHash      String       @map("token_hash")
  tokenType      String       @map("token_type")
  expiresAt      DateTime     @map("expires_at") @db.Timestamptz(6)
  usedAt         DateTime?    @map("used_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy      String?      @map("created_by") @db.Uuid
  security_users SecurityUser @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_security_user_token_user")
  @@index([expiresAt], map: "idx_security_user_token_exp")
  @@map("security_user_token")
}

@@schema(" corpus\)
model SecurityRbac {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleCode        String      @unique @map("role_code") @db.VarChar(50)
  permission_code String?     @db.VarChar(100)
  createdAt       DateTime?   @default(now()) @map("created_at") @db.Timestamp(6)
  roleName        String?     @map("role_name") @db.VarChar(100)
  description     String?
  isActive        Boolean?    @default(true) @map("is_active")
  updatedAt       DateTime?   @default(now()) @map("updated_at") @db.Timestamp(6)
  security_users  SecurityUser[] @relation("UserPrimaryRole")
  user_x_rbac     UserXRbac[]

  @@map("security_rbac")
}

@@schema(" corpus\)
model UserXRbac {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  roleId    String       @map("role_id") @db.Uuid
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  role      SecurityRbac @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_x_rbac_roleid_fkey")
  user      SecurityUser @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_x_rbac_userid_fkey")

  @@unique([userId, roleId], map: "user_x_rbac_user_role_unique")
  @@map("user_x_rbac")
}

@@schema(" corpus\)
model CorpusParam {
  id                   String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String                    @map("tenant_id") @db.Uuid
  paramCode            String                    @unique @map("param_code") @db.VarChar(100)
  paramName            String                    @map("param_name") @db.VarChar(255)
  category             String                    @db.VarChar(50)
  description          String
  technicalDescription String                    @map("technical_description")
  defaultValue         Decimal                   @map("default_value") @db.Decimal
  configurableValue    Decimal                   @map("configurable_value") @db.Decimal
  minAllowedValue      Decimal                   @map("min_allowed_value") @db.Decimal
  maxAllowedValue      Decimal                   @map("max_allowed_value") @db.Decimal
  requiresApproval     Boolean?                  @default(true) @map("requires_approval")
  isActive             Boolean?                  @default(true) @map("is_active")
  isLocked             Boolean?                  @default(false) @map("is_locked")
  versionNumber        Int?                      @default(1) @map("version_number")
  effectiveFrom        DateTime?                 @default(now()) @map("effective_from") @db.Timestamp(6)
  effectiveTo          DateTime?                 @map("effective_to") @db.Timestamp(6)
  createdAt            DateTime?                 @default(now()) @map("created_at") @db.Timestamp(6)
  createdBy            String?                   @map("created_by") @db.Uuid
  updatedAt            DateTime?                 @default(now()) @map("updated_at") @db.Timestamp(6)
  updatedBy            String?                   @map("updated_by") @db.Uuid
  changeLogs           CorpusParamChangeLog[]
  profileValues        CorpusParamProfileValue[]

  @@map("corpus_params")
}

@@schema(" corpus\)
model CorpusParamProfile {
  id             String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String                    @map("tenant_id") @db.Uuid
  profileName    String                    @map("profile_name") @db.VarChar(255)
  jurisdictionId String?                   @map("jurisdiction_id") @db.Uuid
  versionNumber  Int?                      @default(1) @map("version_number")
  hashSnapshot   String?                   @map("hash_snapshot")
  status         String?                   @default("draft") @db.VarChar(50)
  createdAt      DateTime?                 @default(now()) @map("created_at") @db.Timestamp(6)
  approvedAt     DateTime?                 @map("approved_at") @db.Timestamp(6)
  approvedBy     String?                   @map("approved_by") @db.Uuid
  activatedAt    DateTime?                 @map("activated_at") @db.Timestamp(6)
  isActive       Boolean?                  @default(false) @map("is_active")
  values         CorpusParamProfileValue[]

  @@map("corpus_param_profiles")
}

@@schema(" corpus\)
model CorpusParamProfileValue {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId String?             @map("profile_id") @db.Uuid
  paramId   String?             @map("param_id") @db.Uuid
  value     Decimal             @db.Decimal
  createdAt DateTime?           @default(now()) @map("created_at") @db.Timestamp(6)
  param     CorpusParam?        @relation(fields: [paramId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  profile   CorpusParamProfile? @relation(fields: [profileId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("corpus_param_profile_values")
}

@@schema(" corpus\)
model CorpusParamChangeLog {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paramId      String?      @map("param_id") @db.Uuid
  oldValue     Decimal?     @map("old_value") @db.Decimal
  newValue     Decimal?     @map("new_value") @db.Decimal
  changedBy    String?      @map("changed_by") @db.Uuid
  changeReason String?      @map("change_reason")
  changeType   String?      @map("change_type") @db.VarChar(50)
  createdAt    DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  param        CorpusParam? @relation(fields: [paramId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("corpus_param_change_log")
}

@@schema(" corpus\)
model CorpusJurisdiction {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                  String                 @unique
  name                  String
  iso2                  String?
  iso3                  String?
  status                Boolean                @default(false)
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @default(now()) @map("updated_at") @db.Timestamptz(6)
  status_id             Int?                   @db.SmallInt
  companies             CorpusCompany[]
  frameworks            CorpusFramework[]
  corpus_catalog_status corpus_catalog_status? @relation(fields: [status_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_corpus_jurisdiction_status_id")
  security_user_scope   SecurityUserScope[]

  @@map("corpus_jurisdiction")
}

@@schema(" corpus\)
model CorpusFramework {
  id                    String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jurisdictionId        String                   @map("jurisdiction_id") @db.Uuid
  code                  String                   @unique
  name                  String
  description           String?
  status                String                   @default("active")
  createdAt             DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at            DateTime                 @default(now()) @db.Timestamptz(6)
  status_id             Int?                     @db.SmallInt
  jurisdiction          CorpusJurisdiction       @relation(fields: [jurisdictionId], references: [id], onUpdate: NoAction)
  corpus_catalog_status corpus_catalog_status?   @relation(fields: [status_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_corpus_framework_status_id")
  versions              CorpusFrameworkVersion[]

  @@index([jurisdictionId], map: "idx_corpus_framework_jurisdiction_id")
  @@map("corpus_framework")
}

@@schema(" corpus\)
model CorpusFrameworkVersion {
  id                            String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  frameworkId                   String                          @map("framework_id") @db.Uuid
  version                       String
  effectiveDate                 DateTime?                       @map("effective_date") @db.Date
  changelog                     String?
  status                        String                          @default("active")
  createdAt                     DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime                        @default(now()) @map("updated_at") @db.Timestamptz(6)
  statusId                      Int?                            @map("status_id") @db.SmallInt
  assessments                   CorpusAssessment[]
  corpus_control_risk_map       corpus_control_risk_map[]
  corpus_domain                 CorpusDomain[]
  framework                     CorpusFramework                 @relation(fields: [frameworkId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  corpus_catalog_status         corpus_catalog_status?          @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_corpus_framework_version_status_id")
  corpus_parameter_set          CorpusParameterSet[]
  corpus_source                 corpus_source[]
  corpus_test_control_procedure corpus_test_control_procedure[]
  security_user_scope           SecurityUserScope[]

  @@unique([frameworkId, version])
  @@index([frameworkId], map: "idx_corpus_framework_version_framework_id")
  @@map("corpus_framework_version")
}

@@schema(" corpus\)
model CorpusCompany {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                  String                @unique
  name                  String
  legalName             String?               @map("legal_name")
  jurisdictionId        String?               @map("jurisdiction_id") @db.Uuid
  statusId              Int                   @map("status_id") @db.SmallInt
  createdAt             DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime              @default(now()) @map("updated_at") @db.Timestamptz(6)
  assessments           CorpusAssessment[]
  jurisdiction          CorpusJurisdiction?   @relation(fields: [jurisdictionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  corpus_catalog_status corpus_catalog_status @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("corpus_company")
}

@@schema(" corpus\)
model CorpusDomain {
  id                       String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  framework_version_id     String                 @db.Uuid
  code                     String
  name                     String
  description              String?
  status                   String                 @default("active")
  createdAt                DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at               DateTime               @default(now()) @db.Timestamptz(6)
  status_id                Int?                   @db.SmallInt
  corpus_framework_version CorpusFrameworkVersion @relation(fields: [framework_version_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  corpus_catalog_status    corpus_catalog_status? @relation(fields: [status_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_corpus_domain_status_id")
  obligations              CorpusObligation[]
  security_user_scope      SecurityUserScope[]

  @@unique([framework_version_id, code])
  @@index([framework_version_id], map: "idx_corpus_domain_framework_version_id")
  @@map("corpus_domain")
}

@@schema(" corpus\)
model CorpusObligation {
  id                               String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domainId                         String                            @map("domain_id") @db.Uuid
  code                             String
  title                            String
  statement                        String
  source_ref                       String?
  rationale                        String?
  status                           String                            @default("active")
  createdAt                        DateTime                          @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at                       DateTime                          @default(now()) @db.Timestamptz(6)
  status_id                        Int?                              @db.SmallInt
  obligation_type_id               Int?                              @db.SmallInt
  is_hard_gate                     Boolean                           @default(false)
  criticality                      Int                               @default(3) @db.SmallInt
  evidenceStrength                 Int                               @default(3) @map("evidence_strength") @db.SmallInt
  criticalityId                    Int                               @map("criticality_id") @db.SmallInt
  evidence_strength_id             Int                               @db.SmallInt
  controls                         CorpusControlObligation[]
  corpus_material_event            corpus_material_event[]
  modelRunObligations              CorpusModelRunObligation[]
  domain                           CorpusDomain                      @relation(fields: [domainId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  corpus_catalog_criticality       corpus_catalog_criticality        @relation(fields: [criticalityId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_corpus_obligation_criticality_id")
  corpus_catalog_evidence_strength corpus_catalog_evidence_strength  @relation(fields: [evidence_strength_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_corpus_obligation_evidence_strength_id")
  corpus_catalog_obligation_type   corpus_catalog_obligation_type?   @relation(fields: [obligation_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_corpus_obligation_obligation_type_id")
  corpus_catalog_status            corpus_catalog_status?            @relation(fields: [status_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_corpus_obligation_status_id")
  corpus_obligation_risk           corpus_obligation_risk[]
  corpus_obligation_source         corpus_obligation_source[]
  weights                          CorpusParameterObligationWeight[]

  @@unique([domainId, code])
  @@index([criticalityId], map: "idx_corpus_obligation_criticality_id")
  @@index([domainId, criticality], map: "idx_corpus_obligation_domain_criticality")
  @@index([domainId], map: "idx_corpus_obligation_domain_id")
  @@index([domainId, obligation_type_id], map: "idx_corpus_obligation_domain_type")
  @@index([evidence_strength_id], map: "idx_corpus_obligation_evidence_strength_id")
  @@index([obligation_type_id], map: "idx_corpus_obligation_type_id")
  @@map("corpus_obligation")
}

@@schema(" corpus\)
model CorpusControl {
  id                                String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                              String                            @unique
  name                              String
  controlTypeId                     Int                               @map("control_type_id") @db.SmallInt
  automationId                      Int                               @map("automation_id") @db.SmallInt
  frequencyId                       Int                               @map("frequency_id") @db.SmallInt
  description                       String
  ownerRole                         String?                           @map("owner_role")
  evidenceRequired                  Boolean                           @default(true) @map("evidence_required")
  status                            String                            @default("active")
  statusId                          Int                               @default(2) @map("status_id") @db.SmallInt
  createdAt                         DateTime                          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                         DateTime                          @default(now()) @map("updated_at") @db.Timestamptz(6)
  control_objective                 String?
  control_scope                     String?
  is_hard_gate                      Boolean                           @default(false)
  rationale                         String?
  primary_cf_risk_id                String?                           @db.Uuid
  corpus_catalog_control_automation corpus_catalog_control_automation @relation(fields: [automationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  corpus_catalog_control_type       corpus_catalog_control_type       @relation(fields: [controlTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  corpus_catalog_control_frequency  corpus_catalog_control_frequency  @relation(fields: [frequencyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  corpus_risk                       corpus_risk?                      @relation(fields: [primary_cf_risk_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_control_primary_cf")
  corpus_control_artifact           corpus_control_artifact[]
  obligations                       CorpusControlObligation[]
  corpus_control_risk_map           corpus_control_risk_map[]
  evaluationStates                  CorpusEvaluationControlState[]
  corpus_material_event             corpus_material_event[]
  modelRunControls                  CorpusModelRunControl[]
  corpus_test_control               corpus_test_control[]
  corpus_test_control_procedure     corpus_test_control_procedure[]
  corpus_test_control_run           corpus_test_control_run[]

  @@index([primary_cf_risk_id], map: "idx_control_primary_cf")
  @@map("corpus_control")
}

@@schema(" corpus\)
model CorpusControlObligation {
  controlId           String           @map("control_id") @db.Uuid
  obligationId        String           @map("obligation_id") @db.Uuid
  compliance_strength Int              @db.SmallInt
  control             CorpusControl    @relation(fields: [controlId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  obligation          CorpusObligation @relation(fields: [obligationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([controlId, obligationId])
  @@index([obligationId], map: "idx_control_obligation_obl")
  @@map("corpus_control_obligation")
}

@@schema(" corpus\)
model CorpusAssessment {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId             String                 @map("company_id") @db.Uuid
  frameworkVersionId    String                 @map("framework_version_id") @db.Uuid
  name                  String
  scope_notes           String?
  statusId              Int                    @map("status_id") @db.SmallInt
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  created_by            String?
  company               CorpusCompany          @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  frameworkVersion      CorpusFrameworkVersion @relation(fields: [frameworkVersionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  corpus_catalog_status corpus_catalog_status  @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  evaluations           CorpusEvaluation[]
  modelRuns             CorpusModelRun[]

  @@map("corpus_assessment")
}

@@schema(" corpus\)
model CorpusEvaluation {
  id                    String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId          String                         @map("assessment_id") @db.Uuid
  periodStart           DateTime                       @map("period_start") @db.Date
  periodEnd             DateTime                       @map("period_end") @db.Date
  statusId              Int                            @map("status_id") @db.SmallInt
  notes                 String?
  createdAt             DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  created_by            String?
  updatedAt             DateTime                       @default(now()) @map("updated_at") @db.Timestamptz(6)
  assessment            CorpusAssessment               @relation(fields: [assessmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  corpus_catalog_status corpus_catalog_status          @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  artifacts             CorpusEvaluationArtifact[]
  controlStates         CorpusEvaluationControlState[]
  testRuns              CorpusEvaluationTestRun[]
  corpus_material_event corpus_material_event[]
  modelRuns             CorpusModelRun[]

  @@map("corpus_evaluation")
}

@@schema(" corpus\)
model CorpusEvaluationControlState {
  evaluationId            String           @map("evaluation_id") @db.Uuid
  controlId               String           @map("control_id") @db.Uuid
  implementation_status   String
  design_effectiveness    Decimal?         @db.Decimal(6, 4)
  operating_effectiveness Decimal?         @db.Decimal(6, 4)
  notes                   String?
  updated_at              DateTime         @default(now()) @db.Timestamptz(6)
  updated_by              String?
  control                 CorpusControl    @relation(fields: [controlId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  evaluation              CorpusEvaluation @relation(fields: [evaluationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([evaluationId, controlId])
  @@map("corpus_evaluation_control_state")
}

@@schema(" corpus\)
model CorpusEvaluationTestRun {
  evaluationId            String                  @map("evaluation_id") @db.Uuid
  testControlRunId        String                  @map("test_control_run_id") @db.Uuid
  included                Boolean                 @default(true)
  inclusion_reason        String?
  selected_by             String?
  selected_at             DateTime                @default(now()) @db.Timestamptz(6)
  evaluation              CorpusEvaluation        @relation(fields: [evaluationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  corpus_test_control_run corpus_test_control_run @relation(fields: [testControlRunId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([evaluationId, testControlRunId])
  @@map("corpus_evaluation_test_run")
}

@@schema(" corpus\)
model CorpusEvaluationArtifact {
  evaluationId            String                  @map("evaluation_id") @db.Uuid
  artifactId              String                  @map("artifact_id") @db.Uuid
  status                  String
  review_notes            String?
  reviewed_by             String?
  reviewed_at             DateTime?               @db.Timestamptz(6)
  corpus_control_artifact corpus_control_artifact @relation(fields: [artifactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  evaluation              CorpusEvaluation        @relation(fields: [evaluationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([evaluationId, artifactId])
  @@map("corpus_evaluation_artifact")
}

@@schema(" corpus\)
model CorpusModelRun {
  id                          String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId                String                     @map("assessment_id") @db.Uuid
  evaluationId                String                     @map("evaluation_id") @db.Uuid
  parameterSetId              String                     @map("parameter_set_id") @db.Uuid
  engineVersion               String                     @map("engine_version")
  started_at                  DateTime                   @default(now()) @db.Timestamptz(6)
  endedAt                     DateTime?                  @map("ended_at") @db.Timestamptz(6)
  runStatus                   String                     @map("run_status")
  executed_by                 String?
  inputHash                   String                     @map("input_hash")
  outputHash                  String                     @map("output_hash")
  assessment                  CorpusAssessment           @relation(fields: [assessmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  evaluation                  CorpusEvaluation           @relation(fields: [evaluationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
