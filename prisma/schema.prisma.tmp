  corpus_test              corpus_test             @relation(fields: [test_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "corpus_control_test_procedure_test_id_fkey")

  @@unique([control_id, test_id, version], map: "ux_ctl_test_proc_no_fv", where: raw("(framework_version_id IS NULL)"))
  @@unique([control_id, test_id, framework_version_id, version], map: "ux_ctl_test_proc_with_fv", where: raw("(framework_version_id IS NOT NULL)"))
  @@index([control_id, test_id], map: "idx_ctl_test_proc_control_test")
  @@index([effective_from], map: "idx_ctl_test_proc_effective_from")
  @@index([framework_version_id], map: "idx_ctl_test_proc_fv")
  @@index([status_id], map: "idx_ctl_test_proc_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
@@schema(" corpus\)
model corpus_test_control_run {
  id                         String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  control_id                 String                    @db.Uuid
  test_id                    String                    @db.Uuid
  executed_at                DateTime                  @default(now()) @db.Timestamptz(6)
  executed_by                String?
  run_type                   String
  result                     String
  score                      Decimal                   @db.Decimal(6, 4)
  sample_size                Int?
  population_size            Int?
  parameters                 Json?
  query_hash                 String?
  script_version             String?
  output_summary             Json?
  evidence_ref               String?
  notes                      String?
  created_at                 DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime                  @default(now()) @db.Timestamptz(6)
  script_id                  String?                   @db.Uuid
  corpus_evaluation_test_run CorpusEvaluationTestRun[]
  corpus_material_event      corpus_material_event[]
  corpus_control             CorpusControl             @relation(fields: [control_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "corpus_control_test_run_control_id_fkey")
  corpus_test                corpus_test               @relation(fields: [test_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "corpus_control_test_run_test_id_fkey")
  corpus_test_script         corpus_test_script?       @relation(fields: [script_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "corpus_test_control_run_script_fk")

  @@index([control_id, test_id, executed_at(sort: Desc)], map: "idx_ctl_test_run_ctl_test_exec")
  @@index([result], map: "idx_ctl_test_run_result")
  @@index([run_type], map: "idx_ctl_test_run_run_type")
  @@index([test_id, executed_at(sort: Desc)], map: "idx_ctl_test_run_test_exec")
  @@index([script_id], map: "idx_test_control_run_script_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
@@schema(" corpus\)
model corpus_test_script {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  test_id                 String                    @db.Uuid
  code                    String
  name                    String
  engine                  String
  body                    String?
  path                    String?
  version                 String
  hash                    String
  is_active               Boolean                   @default(true)
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  corpus_test_control_run corpus_test_control_run[]
  corpus_test             corpus_test               @relation(fields: [test_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([test_id, code, version])
  @@index([test_id, is_active], map: "idx_test_script_active")
}

@@schema(" corpus\)
model corpus_test_source {
  test_id       String        @db.Uuid
  source_id     String        @db.Uuid
  corpus_source corpus_source @relation(fields: [source_id], references: [id], onUpdate: NoAction)
  corpus_test   corpus_test   @relation(fields: [test_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([test_id, source_id])
}

@@schema(" corpus\)
model llm_master_prompts {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  name        String
  module_name String
  text_area   String?
  prompt      String
  is_active   Boolean  @default(true)
  version     Int      @default(1)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_by  String?

  @@index([code, is_active], map: "idx_master_prompts_active_code")
  @@index([module_name, text_area, is_active], map: "idx_master_prompts_lookup")
}
